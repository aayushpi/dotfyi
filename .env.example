# Newsletter (Resend) — set these in the Vercel project env (Production).
# Resend API key (already configured in your Resend account).
RESEND_API_KEY=

# The Resend Segment your subscribers are added to and that broadcasts target.
# Create it in the Resend dashboard (Segments) and paste its ID here.
RESEND_SEGMENT_ID=

# Verified sender, e.g. "Aayush <notes@aayush.fyi>". Domain must be verified in Resend.
NEWSLETTER_FROM=

# Where the "draft ready for review" heads-up email is sent. Optional but recommended.
NEWSLETTER_NOTIFY_TO=xoxo@aayush.fyi

# Shared secret guarding /api/newsletter/run. Vercel sends this automatically to crons.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# First-run watermark. With no prior sent broadcast, only notes dated AFTER this are
# eligible — keeps your back catalogue out of the first newsletter. Set to launch day.
NEWSLETTER_GENESIS_DATE=2026-06-09

# Optional overrides.
# NEWSLETTER_CADENCE_DAYS=14
# NEXT_PUBLIC_SITE_URL=https://aayush.fyi
